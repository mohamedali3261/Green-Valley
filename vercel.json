{
  "rewrites": [
    {
      "source": "/",
      "destination": "/html/home.html"
    },
    {
      "source": "/home",
      "destination": "/html/home.html"
    },
    {
      "source": "/about",
      "destination": "/html/about.html"
    },
    {
      "source": "/products",
      "destination": "/html/products.html"
    },
    {
      "source": "/blog",
      "destination": "/html/blog.html"
    },
    {
      "source": "/contact",
      "destination": "/html/contact.html"
    },
    {
      "source": "/calendar",
      "destination": "/html/calendar.html"
    },
    {
      "source": "/certificates",
      "destination": "/html/certificates.html"
    },
    {
      "source": "/loading",
      "destination": "/html/loading.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
